# Runtime data dirs (created by the server at run time)
data/
*.log

# Frontend build + deps
frontend/node_modules/
frontend/dist/

# IDE / OS noise
.DS_Store
.vscode/
.idea/
*.swp

# Go build artifacts (compiled binary at repo root, anchored to avoid
# accidentally matching cmd/phronesis/)
/phronesis
*.test
*.out

# webfs/dist is populated from frontend/dist/ by `make build` so a
# `-tags=prod` compile can embed it. Kept out of git on purpose: if it
# were committed, stale placeholder content could ship in a release.
internal/webfs/dist/

# goreleaser output
dist/
